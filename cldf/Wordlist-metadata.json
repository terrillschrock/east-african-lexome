  "dc:conformsTo": "http://cldf.clld.org/v1.0/terms.rdf#Wordlist",
  "dc:title": "East African Lexome (EALex)",
  "dc:description": "A comprehensive comparative lexical database of 420 languages spoken across ten East African nations (Burundi, Eritrea, Ethiopia, Kenya, Rwanda, Somalia, South Sudan, Sudan, Tanzania, Uganda). Designed as research infrastructure for African historical linguistics in the era of computational and quantitative methods.",
  "dc:creator": [
    {
      "name": "Schrock, Terrill",
      "role": "Project Lead"
    }
  ],
  "dc:subject": [
    "African languages",
    "East Africa",
    "historical linguistics",
    "comparative linguistics",
    "lexicostatistics",
    "lexomics"
  ],
  "dc:license": "https://creativecommons.org/licenses/by/4.0/",
  "dc:bibliographicCitation": "Schrock, Terrill (2026). East African Lexome (EALex). Comparative lexical database. https://github.com/terrillschrock/east-african-lexome",
  "rdf:ID": "ealex",
  "rdf:type": "http://www.w3.org/ns/dcat#Dataset",
  "dialect": {
    "commentPrefix": null,
    "delimiter": ",",
    "doubleQuote": true,
    "encoding": "utf-8",
    "header": true,
    "headerRowCount": 1,
    "quoteChar": "\"",
    "skipBlankRows": false,
    "skipColumns": 0,
    "skipInitialSpace": false,
    "skipRows": 0,
    "trim": false
  },
  "tables": [
    {
      "url": "languages.csv",
      "dc:conformsTo": "http://cldf.clld.org/v1.0/terms.rdf#LanguageTable",
      "tableSchema": {
        "columns": [
          {
            "name": "ID",
            "datatype": {
              "base": "string",
              "format": "[a-zA-Z0-9_\\-]+"
            },
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#id",
            "required": true
          },
          {
            "name": "Name",
            "datatype": "string",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#name",
            "required": true
          },
          {
            "name": "Glottocode",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#glottocode",
            "datatype": {
              "base": "string",
              "format": "[a-z0-9]{4}[1-9][0-9]{3}"
            }
          },
          {
            "name": "ISO639P3code",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#iso639P3code",
            "datatype": {
              "base": "string",
              "format": "[a-z]{3}"
            }
          },
          {
            "name": "Latitude",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#latitude",
            "datatype": {
              "base": "decimal",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "Longitude",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#longitude",
            "datatype": {
              "base": "decimal",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "Macroarea",
            "propertyUrl": "http://cldf.clld.org/v1.0/terms.rdf#macroarea"
          },
          {
            "name": "Family",
            "datatype": "string"
          },
          {
            "name": "Subfamily",
            "datatype": "string"
          },
          {
            "name": "Country",
            "datatype": "string"
          },
          {
            "name": "EA_Countries",
            "datatype": "string",
            "dc:description": "All East African countries where the language is spoken (pipe-separated ISO 3166-1 alpha-2 codes)"
          },
          {
            "name": "Speaker_Population",
            "datatype": "string"
          },
          {
            "name": "Endangerment",
            "datatype": {
              "base": "string",
              "format": "not_endangered|threatened|shifting|moribund|nearly_extinct|extinct|"
            }
          },
          {
            "name": "Source_Name",
            "datatype": "string"
          },
          {
            "name": "Comment",
            "datatype": "string"
          }
        ]
      }
